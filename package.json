{
    "name": "gunslinger",
    "version": "1.0.0",
    "description": "",
    "type": "module",
    "main": "src/main.ts",
    "scripts": {
        "start": "node dist/index.js",
        "clean": "rm -rf dist",
        "prebuild": "npm run clean && npm run typecheck",
        "typecheck": "tsc --noEmit",
        "update_content": "./scripts/download_csv_files.cjs",
        "build": "esbuild src/main.ts --bundle --platform=node --format=esm --target=esnext --outfile=dist/index.js --loader:.md=text",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix",
        "test": "mocha",
        "pre-commit": "./node_modules/.bin/lint-staged",
        "prepare": "husky"
    },
    "author": "Ori Gold",
    "license": "ISC",
    "devDependencies": {
        "@types/chai": "^5.2.3",
        "@types/chalk": "^0.4.31",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.10.13",
        "@types/sinon": "^17.0.1",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "chai": "^6.2.2",
        "esbuild": "^0.27.3",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.0.2",
        "eslint-plugin-prettier": "^5.2.3",
        "googleapis": "^169.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.0.0",
        "mocha": "^11.7.5",
        "prettier": "^3.5.3",
        "sinon": "^21.0.0",
        "ts-loader": "^9.4.1",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.11",
        "typescript": "^5.1.6"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.78.0",
        "chalk": "^5.6.2",
        "immer": "^11.1.4",
        "ollama": "^0.6.3",
        "ora": "^9.0.0",
        "zod": "^4.3.6"
    },
    "lint-staged": {
        "*.ts": "npm run lint:fix"
    }
}
