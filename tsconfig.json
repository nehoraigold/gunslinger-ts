{
  "compilerOptions": {
      "target": "esnext",
      "module": "esnext",
      "lib": ["esnext", "dom", "dom.iterable", "dom.asynciterable"],
      "moduleResolution": "node",
      "downlevelIteration": true,
      "strict": true,
      "noImplicitAny": true,
      "strictNullChecks": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "resolveJsonModule": true
  }
}
